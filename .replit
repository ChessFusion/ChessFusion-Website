modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/scripts/start.sh"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[userenv]

[userenv.shared]
VITE_FIREBASE_PROJECT_ID = "chess-fusion-202b2"
VITE_FIREBASE_AUTH_DOMAIN = "chess-fusion-202b2.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET = "chess-fusion-202b2.appspot.com"
